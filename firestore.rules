rules_version = '2';

// ============================================================
// FantasyChama — Phase 12: Hardened Security Rules
// Changes from Phase 11:
//   - Leagues: read now requires authentication (no anonymous sniffing)
//   - Memberships: read requires authentication (protects phone numbers)
//   - League create: requires email verification to prevent fake accounts
//   - mpesa_requests / b2c_requests: tightened update (admin-only)
//   - Deny all catch-all remains the default
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny — anything not explicitly matched is blocked
    match /{document=**} {
      allow read, write: if false;
    }

    // Returns the parent league document data
    function leagueData(leagueId) {
      return get(/databases/$(database)/documents/leagues/$(leagueId)).data;
    }

    function isChairman(leagueId) {
      return request.auth != null &&
             leagueData(leagueId).chairmanId == request.auth.uid;
    }

    function isCoAdmin(leagueId) {
      return request.auth != null &&
             (leagueData(leagueId).get('coAdminId', null) == request.auth.uid ||
              leagueData(leagueId).get('coAdminMapping', null) == request.auth.uid);
    }

    function isAdmin(leagueId) {
      return isChairman(leagueId) || isCoAdmin(leagueId);
    }

    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    // Protects financial fields from being written by non-admins
    function touchesFinancialFields() {
      let sensitive = ['walletBalance', 'role', 'trustScore', 'hasPaid'];
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(sensitive);
    }

    // ──────────────────────────────────────────────────────────────
    // LEAGUES
    // ──────────────────────────────────────────────────────────────
    match /leagues/{leagueId} {
      // Authenticated read only — prevents public scraping of league names,
      // chairman emails, invite codes, and financial rules
      allow read: if isAuthenticated();

      // Only email-verified accounts can create leagues (prevents throwaway signups)
      allow create: if isAuthenticated() && request.auth.token.email_verified == true;

      allow update: if isChairman(leagueId);
      allow delete: if isChairman(leagueId);

      // ── Memberships ───────────────────────────────────────────
      match /memberships/{memberId} {
        // Authenticated read only — phone numbers are PII; no public exposure
        allow read: if isAuthenticated();

        allow create: if isAdmin(leagueId);

        allow update: if
          isAdmin(leagueId)
          ||
          (
            // Member updating their own non-financial profile fields
            isAuthenticated() &&
            (
              resource.data.get('authUid', '') == request.auth.uid ||
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hasAcceptedRules'])
            ) &&
            !touchesFinancialFields()
          )
          ||
          (
            // Member setting their own authUid on first login
            isAuthenticated() &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['authUid']) &&
            request.resource.data.authUid == request.auth.uid
          );

        allow delete: if isChairman(leagueId);
      }

      // ── Notifications ─────────────────────────────────────────
      match /notifications/{notifId} {
        allow read: if isAuthenticated();
        allow create: if isAdmin(leagueId);
        allow update: if isAuthenticated() && (
          isAdmin(leagueId)
          ||
          (
            // Members can only mark notifications as read (append to readBy array)
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']) &&
            request.resource.data.readBy.hasAll(resource.data.readBy)
          )
        );
        allow delete: if isAdmin(leagueId);
      }

      // ── League Events (Ledger feed) ───────────────────────────
      match /league_events/{eventId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAdmin(leagueId);
      }

      // ── Disputes ──────────────────────────────────────────────
      match /disputes/{disputeId} {
        allow read: if isAuthenticated() && (
          isAdmin(leagueId) ||
          resource.data.memberId == request.auth.uid
        );
        allow create: if isAuthenticated() &&
          request.resource.data.memberId == request.auth.uid &&
          request.resource.data.status == 'pending' &&
          request.resource.data.keys().hasAll(['memberId', 'memberName', 'receiptCode', 'amount', 'status']);
        allow update: if isAdmin(leagueId);
        allow delete: if isChairman(leagueId);
      }

      // ── Pending Payouts ───────────────────────────────────────
      match /pending_payouts/{payoutId} {
        allow read: if isAdmin(leagueId);
        allow create: if isChairman(leagueId);
        allow update: if isAdmin(leagueId);
        allow delete: if isChairman(leagueId);
      }

      // ── Winner Confirmations ──────────────────────────────────
      match /winner_confirmations/{confId} {
        allow read: if isAuthenticated() && (
          isAdmin(leagueId) ||
          resource.data.winnerId == request.auth.uid
        );
        allow create: if isAdmin(leagueId);
        allow update: if isAuthenticated() && (
          isAdmin(leagueId)
          ||
          (
            resource.data.winnerId == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
            request.resource.data.status == 'confirmed'
          )
        );
        allow delete: if isAdmin(leagueId);
      }

      // ── Transactions (Immutable Ledger) ───────────────────────
      match /transactions/{txId} {
        allow read: if isAuthenticated() && (
          isAdmin(leagueId) ||
          resource.data.userId == request.auth.uid
        );
        allow create: if isAdmin(leagueId);
        allow update, delete: if false; // Transactions are immutable — never modifiable
      }

      // ── M-Pesa STK Requests ───────────────────────────────────
      match /mpesa_requests/{requestId} {
        allow read: if isAdmin(leagueId);
        allow create: if isAuthenticated();
        // Only admin can update (e.g. backend marks as completed via Admin SDK)
        allow update: if isAdmin(leagueId);
        allow delete: if false;
      }

      // ── Wallet Top-up Requests ────────────────────────────────
      match /wallet_topup_requests/{requestId} {
        allow read: if isAuthenticated() && (isAdmin(leagueId) || resource.data.userId == request.auth.uid);
        allow create: if isAuthenticated();
        allow update: if isAdmin(leagueId);
        allow delete: if false;
      }

      // ── HQ Settlements ────────────────────────────────────────
      match /hq_settlements/{settlementId} {
        allow read: if isAdmin(leagueId);
        allow create: if isChairman(leagueId);
        allow update, delete: if false;
      }

      // ── B2C Payout Requests ───────────────────────────────────
      match /b2c_requests/{requestId} {
        allow read: if isAdmin(leagueId);
        allow create: if isAdmin(leagueId); // Only admin triggers payouts
        allow update: if isAdmin(leagueId); // Status updates by admin/backend only
        allow delete: if false;
      }

    } // end /leagues/{leagueId}

  } // end /databases/{database}/documents
}
